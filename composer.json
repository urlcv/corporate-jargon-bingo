{
    "name": "urlcv/corporate-jargon-bingo",
    "description": "5×5 bingo card of classic corporate jargon and workplace buzzwords. Frontend-only fun at urlcv.com.",
    "type": "library",
    "license": "MIT",
    "keywords": ["corporate", "jargon", "bingo", "buzzwords", "meetings", "humour"],
    "homepage": "https://urlcv.com/tools/corporate-jargon-bingo",
    "authors": [
        {
            "name": "URLCV",
            "homepage": "https://urlcv.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "URLCV\\CorporateJargonBingo\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "URLCV\\CorporateJargonBingo\\Laravel\\CorporateJargonBingoServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
